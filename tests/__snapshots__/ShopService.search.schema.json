            "id",
            "latitude",
            "lineColor",
            "longitude",
            "name"
          ],
          "properties": {
            "id": {
              "type": "integer"
            },
            "latitude": {
              "type": "number"
            },
            "lineColor": {
              "type": "string",
              "j2sEnumRejected": true
            },
            "longitude": {
              "type": "number"
            },
            "name": {
              "type": "string",
              "j2sEnumRejected": true
            }
          }
        }
      },
      "pfm": {
        "type": "string",
        "j2sEnumRejected": true
      },
      "scheduleSaturday": {
        "anyOf": [
          {
            "type": "string",
            "j2sEnumRejected": true
          },
          {
            "type": "null"
          }
        ]
      },
      "scheduleSunday": {
        "anyOf": [
          {
            "type": "string",
            "j2sEnumRejected": true
          },
          {
            "type": "null"
          }
        ]
      },
      "scheduleWeekdays": {
        "anyOf": [
          {
            "type": "string",
            "j2sEnumRejected": true
          },
          {
            "type": "null"
          }
        ]
      },
      "temporarilyClosed": {
        "type": "boolean"
      },
      "warehouse": {
        "type": "boolean"
      },
      "withVariableProduct": {
        "type": "boolean"
      },
      "workTime": {
        "anyOf": [
          {
            "type": "string",
            "enum": [
              "Откроется в 09:00",
              "Откроется в 08:00",
              "Откроется в 10:00",
              "Откроется в 07:30",
              "Откроется в 08:30",
              "Откроется в 09:30",
              "Откроется в 07:00",
              "Открыто до 21:00",
              "Откроется в 11:00",
              "Открыто до 20:00",
              "Откроется в 09:21"
            ]
          },
          {
            "type": "null"
          }
        ]
      }
    }
  }
}