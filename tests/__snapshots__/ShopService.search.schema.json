{
  "type": "array",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "items": {
    "type": "object",
    "required": [
      "address",
      "canPayCard",
      "canPickup",
      "cityId",
      "id",
      "info",
      "isActive",
      "latitude",
      "longitude",
      "metroStations",
      "pfm",
      "scheduleSaturday",
      "scheduleSunday",
      "scheduleWeekdays",
      "temporarilyClosed",
      "warehouse",
      "withVariableProduct",
      "workTime"
    ],
    "properties": {
      "address": {
        "type": "string",
        "j2sEnumRejected": true
      },
      "canPayCard": {
        "type": "boolean"
      },
      "canPickup": {
        "type": "boolean"
      },
      "cityId": {
        "type": "integer"
      },
      "id": {
        "type": "integer"
      },
      "info": {
        "anyOf": [
          {
            "type": "null"
          },
          {
            "type": "string",
            "j2sEnumRejected": true
          }
        ]
      },
      "isActive": {
        "type": "boolean"
      },
      "latitude": {
        "type": "number"
