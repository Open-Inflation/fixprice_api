{
  "type": "array",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "items": {
    "type": "object",
    "required": [
      "address",
      "canPayCard",
      "canPickup",
      "cityId",
      "count",
      "id",
      "info",
      "isActive",
      "latitude",
      "longitude",
      "metroStations",
      "pfm",
      "scheduleSaturday",
      "scheduleSunday",
      "scheduleWeekdays",
      "temporarilyClosed",
      "warehouse",
      "withVariableProduct",
      "workTime"
    ],
    "properties": {
      "address": {
        "type": "string",
        "j2sEnumRejected": true
      },
      "canPayCard": {
        "type": "boolean"
      },
      "canPickup": {
        "type": "boolean"
      },
      "cityId": {
        "type": "integer"
      },
      "count": {
        "type": "integer"
      },
      "id": {
        "type": "integer"
      },
      "info": {
        "type": "null"
      },
      "isActive": {
        "type": "boolean"
      },
      "latitude": {
        "type": "number"
      },
      "longitude": {
        "type": "number"
      },
      "metroStations": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "id",
            "latitude",
            "lineColor",
            "longitude",
            "name"
          ],
          "properties": {
            "id": {
              "type": "integer"
            },
            "latitude": {
              "type": "number"
            },
            "lineColor": {
              "type": "string",
              "enum": [
                "ADACAC",
                "CC4C6E",
                "BAC8E8",
                "88CDCF",
                "CC0066",
                "943E90",
                "EA5B04",
                "BED12C",
                "E74683",
                "0072BA"
              ]
            },
            "longitude": {
              "type": "number"
            },
            "name": {
              "type": "string",
              "j2sEnumRejected": true
            }
          }
        }
      },
      "pfm": {
        "type": "string",
        "j2sEnumRejected": true
      },
      "scheduleSaturday": {
        "type": "string",
        "enum": [
          "10:00-22:00",
          "09:00-21:00",
          "09:00-22:00"
        ]
      },
      "scheduleSunday": {
        "type": "string",
        "enum": [
          "10:00-22:00",
          "09:00-21:00",
          "09:00-22:00"
        ]
      },
      "scheduleWeekdays": {
        "type": "string",
        "enum": [
          "10:00-22:00",
          "09:00-21:00",
          "09:00-22:00"
        ]
      },
      "temporarilyClosed": {
        "type": "boolean"
      },
      "warehouse": {
        "type": "boolean"
      },
      "withVariableProduct": {
        "type": "boolean"
      },
      "workTime": {
        "type": "string",
        "enum": [
          "Откроется в 10:00",
          "Откроется в 09:00"
        ]
      }
    }
  }
}